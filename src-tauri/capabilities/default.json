{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "log:default",
    "process:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "updater:default",
    "shell:default",
    {
      "identifier": "shell:default",
      "allow": [
        {
          "name": "binaries/pocketbase",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ],
  "platforms": [
    "windows"
  ]
}